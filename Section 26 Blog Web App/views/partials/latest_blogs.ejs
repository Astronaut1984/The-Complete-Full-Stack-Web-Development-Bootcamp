<!-- Preview blogs -->
<% if (locals.latestBlogs && locals.latestBlogs.length> 0) {%>
    <div class="container">
        <h2 class="my-4">Latest Blogs</h2>
        <div class="row">
            <% locals.latestBlogs.forEach((blog) => { %>
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">
                                <%= blog.title %>
                            </h5>
                            <p class="card-text text-truncate">
                                <%= blog.content %>
                            </p>
                        </div>
                    </div>
                </div>
                <% }); %>
        </div>
    </div>
    <% } else { %>
        <div class="container">
            <h2 class="my-4">Latest Blogs</h2>
            <div class="row">
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Blog Post 1</h5>
                            <p class="card-text text-truncate">
                                This is a simple card to preview a blog post.
                            </p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Blog Post 2</h5>
                            <p class="card-text text-truncate">
                                This is another simple card to preview a blog post.
                            </p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Blog Post 3</h5>
                            <p class="card-text text-truncate">
                                This is a third simple card to preview a blog post.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <% } %>